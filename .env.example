# ============================================================
# Azure - Configuração geral
# ============================================================

RG_NAME="rg-feedback-platform-dev"
LOCATION="brazilsouth"


# ============================================================
# Rede / VNet / Subnets
# ============================================================

VNET_NAME="vnet-feedback-dev"
VSUBNET_NAME="snet-feedback-dev"
DB_SUBNET_NAME="snet-feedback-postgres-dev"
DB_DNS_ZONE_NAME="feedback-dev.private.postgres.database.azure.com"


# ============================================================
# Key Vault e Storage
# ============================================================

KEY_VAULT_NAME="kv-feedback-seunome01"
STORAGE_ACCOUNT_NAME="stfeedbackseunome01"


# ============================================================
# PostgreSQL Flexible Server
# ============================================================

DB_SERVER_NAME="pg-feedback-seunome01"
DB_ADMIN_USER="feedback"
DB_ADMIN_PASSWORD="troque-por-uma-senha-forte"


# ============================================================
# Azure Communication Services / E-mail
# ============================================================

COMMUNICATION_SERVICE_NAME="acs-feedback-seunome01"
EMAIL_SERVICE_NAME="aes-feedback-seunome01"
EMAIL_DOMAIN_NAME="AzureManagedDomain"
ADMIN_EMAIL="seu-email@dominio.com"


# ============================================================
# Observabilidade
# ============================================================

WORKSPACE_NAME="law-feedback-seunome01"
APP_INSIGHTS_NAME="appi-feedback-seunome01"


# ============================================================
# Azure Functions
# ============================================================

FUNCTION_LOGIN_NAME="func-feedback-seunome-login"
FUNCTION_CORE_NAME="func-feedback-seunome-core"
FUNCTION_REPORT_NAME="func-feedback-seunome-report"


# ============================================================
# Secrets JWT no Key Vault
# ============================================================

PRIVATE_SECRET_NAME="jwt-private-key"
PUBLIC_SECRET_NAME="jwt-public-key"


# ============================================================
# Repositórios GitHub usados no deploy
# ============================================================

LOGIN_REPO="KervinCandido/az-func-feedback-login"
CORE_REPO="KervinCandido/az-func-feedback-core"
REPORT_REPO="KervinCandido/az-func-feedback-report"


# ============================================================
# App Registrations / GitHub OIDC
# ============================================================

GITHUB_LOGIN_APP_NAME="github-actions-feedback-platform-login-seunome01"
GITHUB_CORE_APP_NAME="github-actions-feedback-platform-core-seunome01"
GITHUB_REPORT_APP_NAME="github-actions-feedback-platform-report-seunome01"


# ============================================================
# Flags de execução
# ============================================================

RUN_REPORT_TRIGGER="false"
RUN_CLEANUP="false"
